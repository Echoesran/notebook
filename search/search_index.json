{"config":{"lang":["en"],"separator":"[\\s\\u200b\\-]","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Home","text":"\u6b22\u8fce\u5149\u4e34 <ul> <li>\u5e73\u65f6\u4f1a\u66f4\u65b0\u4e00\u4e9b\u5b66\u4e60\u7b14\u8bb0</li> </ul> \u65bd\u5de5\u4e2d\uff01 <ul> <li>\u65e7\u7248\u535a\u5ba2\u5185\u5bb9\u8f6c\u79fb\u4e2d</li> </ul> \u535a\u5ba2\u603b\u89c8 <ul> <li>\u8bbf\u5ba2\u603b\u4eba\u6570\uff1a \u4eba</li> <li>\u603b\u8bbf\u95ee\u6b21\u6570\uff1a \u6b21</li> </ul>"},{"location":"aboutme/","title":"\u4eba\u751f\u5b88\u5219\u6e05\u5355","text":"<ul> <li>1.\u6781\u5ea6\u5766\u8bda\u3002</li> <li>2.\u7ba1\u7406\u6b32\u671b\uff1a\u5c24\u5176\u4e0d\u8981\u7eb5\u5bb9\u638c\u63a7\u6b32\u3001\u62d6\u5ef6\u6b32\uff0c\u5c3d\u91cf\u907f\u514d\u4e0e\u4eba\u4e89\u8bba\u3002</li> <li>3.\u5bf9\u5168\u4e16\u754c\u795b\u9b45\u3002</li> <li>4.\u505a\u5bf9\u7684\u4e8b\uff0c\u628a\u4e8b\u505a\u5bf9\u3002</li> <li>5.\u4e0d\u8981\u8ba9\u91cd\u8981\u7684\u4e8b\u53d8\u6210\u7d27\u6025\u7684\u4e8b\u3002</li> <li>6.\u77e5\u884c\u5408\u4e00\u3002</li> <li>7.\u4ece\u5fae\u5c0f\u7684\u884c\u52a8\u5f00\u59cb\u3002</li> <li>8.\u4e0d\u8981\u504f\u542c\u504f\u4fe1\uff0c\u81ea\u5df1\u9a8c\u8bc1\u3002</li> <li>9.\u548c\u8c01\u4e00\u8d77\u5de5\u4f5c\u3001\u751f\u6d3b\uff0c\u8fd9\u5f88\u91cd\u8981\u3002</li> <li>10.\u77e5\u9053\u81ea\u5df1\u7684\u5177\u4f53\u7684\u95ee\u9898\uff0c\u4ece\u89e3\u51b3\u90a3\u4e00\u4e2a\u95ee\u9898\u5f00\u59cb\u3002\u4e0d\u8981\u5e7b\u60f3\u95ee\u9898\uff0c\u4e0d\u8981\u5962\u6c42\u522b\u4eba\u5199\u7684\u653b\u7565\u3002</li> <li>11.\u5c3d\u91cf\u5ba1\u614e\u5730\u8bf4\u8bdd\uff0c\u4e0d\u8bf4\u4e0d\u77e5\u9053\u7684\u8bdd\u3002</li> <li>12.\u6b63\u786e\u7684\u9009\u62e9\u4e0d\u4f1a\u7ea0\u7ed3\u3002</li> <li>13.follow your heart\u3002</li> <li>14.\u505a\u4e0d\u505a\u4e00\u4ef6\u4e8b\u7684\u5224\u65ad\u6807\u51c6\u5f88\u7b80\u5355\uff0c\u4e0d\u505a\u4f1a\u4e0d\u4f1a\u540e\u6094\u3001\u505a\u4e86\u6709\u4ec0\u4e48\u4ee3\u4ef7\uff0c\u7b80\u5355\u4f30\u7b97ROI\u3002</li> <li>15.\u4e00\u4e9b\u95ee\u9898\u53ef\u4ee5\u5148\u4e0d\u89e3\u51b3\uff0c\u4ea4\u7ed9\u65f6\u95f4\u548c\u547d\u8fd0\uff0c\u524d\u63d0\u662f\u8981\u6301\u7eed\u505a\u4e8b\u548c\u601d\u8003\u3002</li> <li>16.\u8868\u8fbe\u611f\u8c22\u548c\u559c\u6b22\u662f\u4eba\u7c7b\u6700\u4f73\u6587\u660e\u3002</li> <li>17.\u5efa\u7acb\u6846\u67b6\u601d\u7ef4\uff0c\u5305\u62ec\u4eba\u751f\u5230\u5177\u4f53\u4e1a\u52a1\u573a\u666f\u3002</li> <li>18.\u6c38\u8fdc\u4e0d\u8981\u9677\u5165\u77ed\u89c6\u9891\u7684\u90aa\u6076\u9677\u8fdb\uff0c\u5c11\u5237\u5c0f\u7ea2\u4e66\u548c\u5fae\u535a\uff0c\u5c11\u73a9\u624b\u673a\u6c42\u4f60\u4e86\u3002\u4fdd\u6301\u7528\u8111\u536b\u751f\u3002</li> <li>19.\u5f97\u5230\u662f\u6700\u597d\u7684\u795b\u9b45\u65b9\u5f0f\uff0c\u4e0d\u8981\u5728\u6ca1\u6709\u771f\u6b63\u5f97\u5230\u7684\u65f6\u5019\u8f7b\u6613\u6839\u636e\u8ba4\u77e5\u505a\u51fa\u5224\u65ad\uff0c\u518d\u6839\u636e\u8ba4\u77e5\u5224\u65ad\u9009\u62e9\u3002</li> <li>20.\u4e0e\u4eba\u4e3a\u5584\uff0c\u5e7f\u7ed3\u5584\u7f18\u3002</li> <li>21.\u73cd\u60dc\u65f6\u95f4\u4ef7\u503c\u3002</li> <li>\u201c\u6839\u636e\u76ee\u6807\u4f30\u7b97\u51fa\u65f6\u95f4\u7684\u4ef7\u503c\uff0c\u5c31\u662f\u505a\u9009\u62e9\u7684\u673a\u4f1a\u6210\u672c\uff0c\u6bcf\u4e00\u5206\u949f\u90fd\u662f\u7b97\u5f97\u51fa\u6765\u7684\u3002\u65e0\u6cd5\u505a\u51b3\u7b56\u4e3b\u8981\u662f\u56e0\u4e3a\u6ca1\u6709\u951a\u5b9a\u7269\uff0c\u4e0d\u77e5\u5982\u4f55\u8ba1\u7b97\u3002\u5982\u679c\u4f60\u6309\u7167\u65f6\u95f4\u6295\u5411\u4e0e\u673a\u4f1a\u6210\u672c\u6765\u6784\u5efa\u601d\u7ef4\u7cfb\u7edf\uff0c\u90a3\u4e48\u5927\u4e8b\u5c0f\u4e8b\u65e0\u975e\u5c31\u662f\u5927\u8d44\u6e90\u5c0f\u8d44\u6e90\u7684\u8ba1\u7b97\u800c\u5df2\u3002\u62d6\u5ef6\u3001\u6267\u884c\u529b\u5dee\uff0c\u672c\u8d28\u662f\u6ca1\u60f3\u6e05\u695a\u3001\u7b97\u6e05\u695a\u3002\u201d</li> <li>22.\u65e2\u6015\u4f55\u5fc5\u60f3\uff0c\u65e2\u60f3\u4f55\u5fc5\u6015\u3002</li> <li>23.\u591a\u770b\u4e8b\u5b9e\uff0c\u5c11\u770b\u89c2\u70b9\u3002solid\u3002</li> <li>24.\u4e00\u5207\u90fd\u662f\u53ef\u4ee5\u4e89\u53d6\u7684\uff0c\u4ece\u8ba9\u4e16\u754c\u770b\u5230\u4f60\u7684\u9762\u5b54\uff0c\u5230\u8ba9\u4e16\u754c\u542c\u5230\u4f60\u7684\u58f0\u97f3\uff0c\u518d\u5230\u8ba9\u4e16\u754c\u611f\u53d7\u5230\u4f60\u7684\u5b58\u5728\u548c\u4ef7\u503c\u3002</li> <li>25.\u70ed\u7231\u547d\u8fd0\uff0c\u5168\u60c5\u6295\u5165\uff0c\u73a9\u597d\u8fd9\u573a\u6e38\u620f\u3002</li> <li>26.\u60f3\u89e3\u51b3\u95ee\u9898\uff0c\u5c31\u8981\u7ad9\u5728\u522b\u4eba\u7684\u89d2\u5ea6\uff0c\u4ece\u522b\u4eba\u7684\u5229\u76ca\u51fa\u53d1\u6765\u5e2e\u81ea\u5df1\u5b8c\u6210\u76ee\u6807\u3002</li> <li>27.\u4e0d\u8981\u9a84\u50b2\uff0c\u4e0d\u8981\u6cbe\u6cbe\u81ea\u559c\u81ea\u5df1\u8eab\u4e0a\u7684\u6807\u7b7e\u3002</li> <li>28.social\u804a\u5929\u7684\u65f6\u5019\u505a\u8f93\u51fa\u578b\u7684\u4eba\uff0c\u5373\u5b66\u4f1a\u804a\u522b\u4eba\u7684\u8bdd\u9898\u3002</li> <li>29.\u4e0d\u8981\u5bb3\u6015\u72af\u9519\uff0c\u5bf9\u9519\u8bef\u5f52\u6839\u7a76\u5e95\u3002</li> <li>30.80%\u7684\u7cbe\u529b\u5e94\u8be5\u653e\u572820%\u7684\u4e8b\u60c5\u4e0a\u3002</li> </ul>"}]}